{
  "rules": {
    "users": {
      ".read": "auth.uid !== null",
      ".write": "auth.uid !== null",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid",
        "balance": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "adsWatched": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "referrals": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "referralEarnings": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "lastBonusClaim": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "lastAdTime": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "dailyLimit": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "telegramId": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "username": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "firstName": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "isBanned": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        },
        "isAdmin": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "withdrawals": {
      ".read": "auth.uid !== null",
      ".write": "auth.uid !== null",
      "$withdrawId": {
        ".validate": "newData.hasChildren(['userId', 'amount', 'method', 'accountNumber', 'status', 'createdAt'])",
        "userId": {
          ".validate": "newData.val() === auth.uid"
        },
        "amount": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "method": {
          ".validate": "newData.isString() && (newData.val() === 'bKash' || newData.val() === 'Nagad' || newData.val() === 'Rocket')"
        },
        "accountNumber": {
          ".validate": "newData.isString() && newData.val().length >= 5"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'rejected')"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "processedAt": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "processedBy": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "username": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "ad_logs": {
      ".read": "auth.uid !== null",
      ".write": "auth.uid !== null",
      "$logId": {
        ".validate": "newData.hasChildren(['userId', 'timestamp', 'reward'])",
        "userId": {
          ".validate": "newData.val() === auth.uid"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "reward": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "adType": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "referrals": {
      ".read": "auth.uid !== null",
      ".write": "auth.uid !== null",
      "$uid": {
        "referredBy": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid",
          ".validate": "newData.isString()"
        },
        "referralsList": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid"
        }
      }
    }
  }
}
